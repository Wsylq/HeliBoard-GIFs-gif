<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp"
    android:clickable="true"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/gif_query_field"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Search GIFs"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:cursorVisible="true"
            android:textColor="@color/gif_search_text"
            android:textColorHint="@color/gif_search_hint" />
        <!-- Clear text button -->
        <ImageButton
            android:id="@+id/btn_clear_gif"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:contentDescription="@string/clear_text"
            android:visibility="gone"
            android:background="@android:drawable/btn_default" />

        <ImageButton
            android:id="@+id/btn_search_gif"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@android:drawable/ic_menu_search"
            android:contentDescription="Search GIFs" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/gif_results_grid"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>